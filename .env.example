# =============================================================================
# .env.example — Customer Intelligence & Analytics Platform
#
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL (REQUIRED — no default)
# Format: mysql+mysqlconnector://user:password@host:port/dbname
# -----------------------------------------------------------------------------
MYSQL_DSN=mysql+mysqlconnector://user:password@localhost:3306/choice_analytics

# -----------------------------------------------------------------------------
# Qdrant vector database
# Default: http://localhost:6333
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# API key — leave blank (or omit) for local/unauthenticated Qdrant instances.
# Required for Qdrant Cloud.
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Embedding model
# Default: BAAI/bge-m3  (Apache-2.0, 100+ languages, 1024-dim → projected to 1536)
# -----------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3

# Output vector dimensionality (must match the Qdrant collection configuration)
EMBED_DIM=1536

# -----------------------------------------------------------------------------
# Sync pipeline tuning
# -----------------------------------------------------------------------------

# Number of MySQL rows fetched per pipeline iteration
SYNC_BATCH_SIZE=500

# Configurable lag window: how many minutes behind real-time the pipeline runs.
# Valid range: 1–1440 (default: 15)
SYNC_LAG_MINUTES=15

# Maximum number of chunks generated from a single source record
MAX_CHUNKS=500

# Maximum tokens per chunk (before splitting)
CHUNK_MAX_TOKENS=512

# Overlapping tokens between consecutive chunks
CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# Dead-letter queue
# -----------------------------------------------------------------------------

# Number of retry attempts before a failed record is written to dead_letter_queue
DLQ_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Scraper — platform credentials
# -----------------------------------------------------------------------------

# Firecrawl API key — required for LinkedIn, Facebook, Twitter/X, Instagram.
# Get yours at https://www.firecrawl.dev
# YouTube uses yt-dlp and needs no credential.
FIRECRAWL_API_KEY=fc-your-key-here

# ---------------------------------------------------------------------------
# Platform credentials — dedicated scrapers (preferred over Firecrawl)
# ---------------------------------------------------------------------------

# Instagram — uses instagrapi (Instagram's private mobile API)
# Use your personal or company Instagram account login.
# Sessions are cached to .instagram_session.json to minimise login attempts.
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# LinkedIn — uses linkedin-api (LinkedIn's Voyager internal API)
# Use your personal LinkedIn account login (email + password).
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Facebook — uses facebook-scraper (Facebook web scraping)
# Use your personal or company Facebook account login.
FACEBOOK_EMAIL=your_facebook_email@example.com
FACEBOOK_PASSWORD=your_facebook_password

# Twitter/X — uses twikit (Twitter's internal GraphQL API, no official API key needed)
# Session cookies saved to .twitter_cookies.json after first login.
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email@example.com
TWITTER_PASSWORD=your_twitter_password

# ---------------------------------------------------------------------------
# AI Analytics (page 5) — local Ollama inference, no API key needed
# ---------------------------------------------------------------------------

# Ollama server URL (default: local)
# Install Ollama: https://ollama.com
OLLAMA_HOST=http://localhost:11434

# Model to use — must be < 7B parameters.
# Recommended options (pull with: ollama pull <model>):
#   llama3.2:3b   — Meta Llama 3.2, 3B params  (best overall, default)
#   phi3.5:3.8b   — Microsoft Phi-3.5, 3.8B    (great instruction following)
#   gemma2:2b     — Google Gemma 2, 2B          (fastest, lightest)
#   qwen2.5:3b    — Alibaba Qwen 2.5, 3B        (strong multilingual)
OLLAMA_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Cerebras — fast cloud inference for the chatbot (optional)
# ---------------------------------------------------------------------------
# When set, the Ask AI chatbot uses Cerebras (very fast) as the primary model
# and automatically falls back to the local Ollama model above when the daily
# free limit is hit or any error occurs. Leave blank to use Ollama only.
# Free tier: ~1M tokens/day. Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Model id (e.g. llama-3.3-70b, gpt-oss-120b, qwen-3-32b)
CEREBRAS_MODEL=llama-3.3-70b
